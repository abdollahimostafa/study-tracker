// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model StudyLog {
  id        String   @id @default(cuid())
  topic     String   // مبحث دستیاری
  hours     Float    // مدت زمان مطالعه به ساعت
  user      String   // "mostafa" یا "saghar"
  note      String?  // <--- اضافه کردن این فیلد به صورت اختیاری
  createdAt DateTime @default(now())
}